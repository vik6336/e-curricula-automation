# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key — get from https://aistudio.google.com/app/apikey
# ROTATE THIS KEY immediately if you suspect it has been exposed in git history
GEMINI_API_KEY=your_gemini_api_key_here

# Shared secret between the React UI and FastAPI.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change_me_to_a_strong_random_hex_string

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated allowed CORS origins (add your server's internal IP/hostname)
# Example: http://localhost:5173,http://192.168.1.42:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# How long portal credentials live in server memory (seconds) before auto-wipe
CREDENTIAL_TTL_SECONDS=600

# Set to "true" in production — disables debug screenshots
PRODUCTION=false

# ── React UI (baked in at build time) ────────────────────────────────────────
# Must match INTERNAL_API_KEY above. Prefix with VITE_ so Vite exposes it.
VITE_API_KEY=change_me_to_a_strong_random_hex_string
